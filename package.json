{
  "name": "@mydecisive/roi-calculator",
  "version": "0.1.0",
  "description": "Embeddable React micro-front-end for estimating MyDecisive SmartHub observability ROI.",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://mydecisive.github.io/roi-calculator/",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/roi-calculator.css",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/roi-calculator.css"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "npm run build:lib",
    "build:demo": "vite build",
    "build:lib": "cross-env BUILD_TARGET=lib vite build",
    "build:pages": "npm run build:demo",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "validate": "npm run typecheck && npm run lint && npm test && npm run build:lib && npm run build:demo"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "typescript-eslint": "^8.19.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
